---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CV" description="Curriculum vitae of Gavin Robert Foster.">
  <div class="page-hero">
    <div class="container">
      <p class="section-label">Curriculum Vitae</p>
      <h1>Gavin Robert Foster</h1>
      <div class="cv-contact">
        <span>Department of Philosophy, Purdue University</span>
        <span class="sep">·</span>
        <span>foste362 AT purdue DOT edu</span>
        <span class="sep">·</span>
        <a href="/cv.pdf" target="_blank">Download PDF</a>
      </div>
    </div>
  </div>

  <div class="container page-body">

    <section class="cv-section">
      <h2>Research Interests</h2>
      <p>Philosophy of Mind &amp; Cognitive Science · Comparative &amp; Developmental Psychology · Philosophy of Biology · Kant's Theoretical and Moral Philosophy · History and Philosophy of Science · History of Analytic Philosophy</p>
    </section>

    <section class="cv-section">
      <h2>Education</h2>
      <div class="cv-entries">
        <div class="cv-entry">
          <div class="cv-year">2024–2030</div>
          <div class="cv-content">
            <strong>PhD, Philosophy</strong>, Purdue University, West Lafayette, IN<br/>
            <span class="cv-note">Dean's Graduate Fellow, College of Liberal Arts (one of four incoming students selected).</span>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2023–2024</div>
          <div class="cv-content">
            <strong>Visiting Graduate Scholar</strong>, Department of Psychology &amp; Brain Sciences, Johns Hopkins University, Baltimore, MD<br/>
            <span class="cv-note">Supervised by Prof. Christopher Krupenye (Social and Cognitive Origins Group). Helped launch the Canine Minds Collaborative dog lab and designed theory-of-mind experiments with dogs. Remains an affiliate of the group.</span>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2022–2024</div>
          <div class="cv-content">
            <strong>MA, Philosophy</strong>, Carleton University, Ottawa, ON<br/>
            <span class="cv-note">GPA 4.00/4.00. Thesis nominated for the Senate Medal: "Mindreading in Great Apes: Dissolving the Logical Problem and a New Multiple Soft-Indicators Model." Supervisors: Myrto Mylopoulos, Andrew Brook.</span>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2022</div>
          <div class="cv-content">
            <strong>BA (Honours), Philosophy</strong>, University of Toronto, Toronto, ON<br/>
            <span class="cv-note">Minors in History &amp; Philosophy of Science and Indigenous Studies. GPA 3.92/4.00. Governor General's Medal (2017). Undergraduate research with Prof. Franz Huber on Davidson and Bayesian philosophy of science.</span>
          </div>
        </div>
      </div>
    </section>

    <section class="cv-section">
      <h2>Publications</h2>
      <div class="cv-entries">
        <div class="cv-entry">
          <div class="cv-year">2026</div>
          <div class="cv-content">
            Bastos, A. P. M., Foster, G. R., &amp; Krupenye, C. "Do dogs rationally infer the causes of failed actions?" <em>PLOS ONE</em> 21(2): e0341872.
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2026</div>
          <div class="cv-content">
            Foster, G. R., &amp; Westra, E. Review of <em>Acting for Reasons: In Defence of Common-Sense Psychology</em>, by Emma Borg. <em>Mind</em>.
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2025</div>
          <div class="cv-content">
            Foster, G. R. "From Monkeys to Infants: The Empirical Challenges Facing Mental Fictionalism." <em>Philosophical Psychology</em>.
          </div>
        </div>
      </div>
    </section>

    <section class="cv-section">
      <h2>Selected Grants, Awards &amp; Honours</h2>
      <div class="cv-entries">
        <div class="cv-entry">
          <div class="cv-year">2026</div>
          <div class="cv-content">Student Award for Best Graduate Paper in Philosophy, Southern Society for Philosophy and Psychology</div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2026</div>
          <div class="cv-content">PROMISE Grant, "Animal Minds: New Theories and New Observations," Purdue University</div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2024–2028</div>
          <div class="cv-content">SSHRC CGS-D, "Middle-Ground Conceptualism, Non-Human Animals, and Persistent Challenges in Comparative Psychology" <span class="cv-note">(score 11.07/12)</span></div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2024–2030</div>
          <div class="cv-content">Dean's Graduate Fellow, Purdue University</div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2024</div>
          <div class="cv-content">PROMISE Grant, "Triadic Approaches in Philosophy of Science," Purdue University</div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2024</div>
          <div class="cv-content">Dr. Thomas Betz Memorial Award, Carleton University</div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2023</div>
          <div class="cv-content">SSHRC Michael Smith Foreign Study Supplement; Michel Gaulin Travel Bursary in the Humanities, Carleton University</div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2023</div>
          <div class="cv-content">SSHRC CGS-M, "The Emergence of Thought: Continual or All-at-Once"; Ontario Graduate Scholarship, Carleton University</div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2022</div>
          <div class="cv-content">Douglas Bond Symons Prize in Philosophy (highest graduating GPA in philosophy); Margaret Wade Labarge Fund, University of Toronto, Trinity College</div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2017</div>
          <div class="cv-content">Chancellor R. C. Berkinshaw Scholarship; University of Toronto Scholar, Trinity College</div>
        </div>
      </div>
    </section>

    <section class="cv-section">
      <h2>Conference Talks</h2>
      <p>Fourteen conference presentations and invited talks (2023–2026), including the International Conference on Comparative Cognition, the Society for Philosophy and Psychology, and invited talks in Athens and Cardiff. <a href="/publications">See the full list →</a></p>
    </section>

    <section class="cv-section">
      <h2>Teaching</h2>
      <div class="cv-entries">
        <div class="cv-entry">
          <div class="cv-year">2025–2026</div>
          <div class="cv-content">
            <strong>Lecturer</strong>, Purdue University<br/>
            <span class="cv-note">"What Animals Tell Us About Human Nature" (Su 2026); "Philosophical Investigations Through Videogames" (Su 2025, Su 2026); "AI and You" (Su 2025).</span>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2022–2024</div>
          <div class="cv-content">
            <strong>Teaching Assistant</strong>, Carleton University<br/>
            <span class="cv-note">Introduction to Logic; Language and Communication; Pragmatics.</span>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2020</div>
          <div class="cv-content">
            <strong>Teaching Assistant</strong>, Esprit Academy, Toronto<br/>
            <span class="cv-note">Taught disabled children (ages 5 to 12) across core subjects; supported students with sensory disorders and ADHD.</span>
          </div>
        </div>
      </div>
    </section>

    <section class="cv-section">
      <h2>Editorial &amp; Service</h2>
      <div class="cv-entries">
        <div class="cv-entry">
          <div class="cv-year">2018–2021</div>
          <div class="cv-content"><strong>Editor-in-Chief</strong> (2020–21), Senior &amp; Junior Editor, <em>Noesis</em> Undergraduate Journal for Philosophy</div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2018–2021</div>
          <div class="cv-content"><strong>Editor-in-Chief</strong> (2019–21), Senior Editor, <em>Almagest</em> Undergraduate Journal for the History &amp; Philosophy of Science</div>
        </div>
        <div class="cv-entry">
          <div class="cv-year">2019–2020</div>
          <div class="cv-content"><strong>Vice-President</strong>, History &amp; Philosophy of Science Undergraduate Society, University of Toronto</div>
        </div>
      </div>
    </section>

    <section class="cv-section">
      <h2>Areas of Specialization &amp; Competence</h2>
      <p><strong>AOS:</strong> Philosophy of Mind, Philosophy of Cognitive Science, Comparative &amp; Developmental Psychology</p>
      <p style="margin-top:0.5rem"><strong>AOC:</strong> Philosophy of Biology, Kant, History &amp; Philosophy of Science, History of Analytic Philosophy</p>
    </section>

  </div>
</Layout>

<style>
.page-hero {
  padding: 4rem 0 3rem;
  border-bottom: 1px solid var(--border);
  background: var(--bg-alt);
}
.page-hero h1 { margin-top: 0.5rem; }
.cv-contact {
  font-size: 0.85rem;
  color: var(--ink-light);
  margin-top: 0.75rem;
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  align-items: center;
}
.sep { color: var(--border); }

.page-body { padding-top: 3.5rem; padding-bottom: 5rem; }

.cv-section { margin-bottom: 3rem; }
.cv-section h2 {
  font-size: 1.1rem;
  border-bottom: 1px solid var(--border);
  padding-bottom: 0.5rem;
  margin-bottom: 1.25rem;
  color: var(--ink);
}

.cv-entries { display: flex; flex-direction: column; gap: 1.1rem; }
.cv-entry {
  display: grid;
  grid-template-columns: 110px 1fr;
  gap: 1.5rem;
  align-items: start;
}
.cv-year {
  font-size: 0.8rem;
  color: var(--ink-faint);
  font-weight: 600;
  padding-top: 0.15rem;
  text-align: right;
}
.cv-content {
  font-size: 0.92rem;
  line-height: 1.6;
}
.cv-note {
  color: var(--ink-light);
  font-size: 0.85rem;
}

@media (max-width: 600px) {
  .cv-entry { grid-template-columns: 1fr; gap: 0.25rem; }
  .cv-year { text-align: left; }
}
</style>
